# =========================================================
# RiBuzz AI - Variables de entorno
# Copiar a .env.local (NO commitear) y completar valores.
# =========================================================

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ.............         # Puede ir en cliente
SUPABASE_SERVICE_ROLE_KEY=eyJ..........                # SOLO servidor

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=jose@ribuzz.co                            # Coma-separado

# ---------- n8n Multi-Agent Workflow ----------
# URL pública del webhook del workflow ribuzz-multi-agent-workflow.json
# Obtenida del nodo Webhook (entry) → Production URL en n8n
N8N_WEBHOOK_URL=https://n8n.srv1097452.hstgr.cloud/webhook/ribuzz-diagnostic
N8N_WEBHOOK_SECRET=cambia-esto-por-algo-largo-y-aleatorio
# Importante: el mismo valor de N8N_WEBHOOK_SECRET debe estar
# configurado en n8n como variable de entorno RIBUZZ_WEBHOOK_SECRET.

# ---------- Wompi (pagos - Fase 4, opcional para MVP) ----------
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...                         # SOLO servidor

# ---------- Claude API (legacy / solo si vuelves al modo direct) ----------
# Solo necesarias si decides regresar a llamadas Claude directas desde Next.js
# en vez de a través de n8n. En modo n8n estas viven en n8n, no aquí.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5
